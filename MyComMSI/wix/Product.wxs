<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
	<Product Id="*" Name="MyComMSI" Language="1033" Version="1.0.0.0" Manufacturer="Crispin" UpgradeCode="d1f4e8a2-7c6b-4f9c-bd32-123456789abc">
		<Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" Platform="x64" />

		<MediaTemplate EmbedCab="yes" />

		<Feature Id="MainFeature" Title="MyComMSI Feature" Level="1">
			<ComponentRef Id="MyComDLLComponent" />
		</Feature>

		<Directory Id="TARGETDIR" Name="SourceDir">
			<Directory Id="ProgramFiles64Folder">
				<Directory Id="INSTALLFOLDER" Name="MyComMSI">
					<Component Id="MyComDLLComponent" Guid="a3f8b2c1-4e6d-4f1a-91b8-56789abcd234" Win64="yes">
						<File Id="MyComDLLFile" Source="D:\Output\MyComMSI.dll" KeyPath="yes" />
					</Component>
				</Directory>
			</Directory>
		</Directory>

		<!-- Immediate action: sets the DLL path -->
		<CustomAction Id="SetRegisterComData"
					  Property="CustomActionData"
					  Value="[INSTALLFOLDER]MyComMSI.dll" />

		<CustomAction Id="SetUnregisterComData"
					  Property="CustomActionData"
					  Value="[INSTALLFOLDER]MyComMSI.dll" />

		<!-- Debug logging: log CustomActionData, not RegisterCom -->
		<CustomAction Id="LogRegisterComData"
					  Execute="immediate"
					  Script="vbscript"
					  Return="ignore">
			<![CDATA[
  Session.Log("DEBUG: CustomActionData = " & Session.Property("CustomActionData"))
  ]]>
		</CustomAction>

		<!-- Register COM during install -->
		<CustomAction Id="RegisterCom"
					  Directory="TARGETDIR"
					  Execute="deferred"
					  Impersonate="no"
					  ExeCommand='"C:\Windows\Microsoft.NET\Framework64\v4.0.30319\regasm.exe" "[CustomActionData]" /codebase /tlb /nologo'
					  Return="check" />

		<!-- Unregister COM during uninstall -->
		<CustomAction Id="UnregisterCom"
					  Directory="TARGETDIR"
					  Execute="deferred"
					  Impersonate="no"
					  ExeCommand='"C:\Windows\Microsoft.NET\Framework64\v4.0.30319\regasm.exe" "[CustomActionData]" /unregister /nologo'
					  Return="ignore" />

		<!-- Schedule the custom actions -->
		<InstallExecuteSequence>
			<Custom Action="SetRegisterComData" Before="RegisterCom">NOT Installed</Custom>
			<Custom Action="LogRegisterComData" After="SetRegisterComData">NOT Installed</Custom>
			<Custom Action="RegisterCom" After="InstallFiles">NOT Installed</Custom>

			<Custom Action="SetUnregisterComData" Before="UnregisterCom">REMOVE="ALL"</Custom>
			<Custom Action="UnregisterCom" Before="RemoveFiles">REMOVE="ALL"</Custom>
		</InstallExecuteSequence>

	</Product>
</Wix>